{
  "$schema": "../mcp/schema-spec.md",
  "sheet": "итерации",
  "headerRow": 1,
  "primaryKey": ["id"],
  "columns": {
    "project": {
      "header": "Проект",
      "type": "string"
    },
    "id": {
      "header": "ID итерации",
      "type": "string"
    },
    "number": {
      "header": "# итерации",
      "type": "number",
      "numberFormat": "0"
    },
    "total": {
      "header": "Всего",
      "type": "number",
      "numberFormat": "#,##0.00",
      "horizontalAlignment": "RIGHT"
    },
    "paid": {
      "header": "Оплачено ($)",
      "type": "number",
      "numberFormat": "#,##0.00",
      "horizontalAlignment": "RIGHT"
    },
    "remaining": {
      "header": "Остаток ($)",
      "type": "number",
      "numberFormat": "#,##0.00",
      "horizontalAlignment": "RIGHT"
    },
    "currency": {
      "header": "Валюта",
      "type": "enum",
      "values": ["USD", "SOM", "EUR", "RUB"],
      "validation": "strict"
    },
    "start": {
      "header": "Начало",
      "type": "date",
      "numberFormat": "DD.MM.YYYY",
      "horizontalAlignment": "RIGHT"
    }
  },
  "sheetProperties": {
    "frozenRows": 1,
    "headerStyle": {
      "textFormat": { "bold": true },
      "backgroundColor": "#e8eaed",
      "horizontalAlignment": "CENTER"
    }
  }
}
