{
  "$schema": "../mcp/schema-spec.md",
  "sheet": "расходы",
  "headerRow": 1,
  "primaryKey": ["date", "amount", "category", "description"],
  "columns": {
    "date": {
      "header": "Дата",
      "type": "date",
      "numberFormat": "DD.MM.YYYY",
      "horizontalAlignment": "RIGHT"
    },
    "category": {
      "header": "Категория",
      "type": "enum",
      "values": [
        "ФОТ",
        "Налоги",
        "Маркетинг и реклама",
        "EAI Google",
        "Аренда офис",
        "Комиссия банка",
        "Офисные припасы",
        "Наемные рабоники вне штата",
        "Сервера и подписки",
        "Другое"
      ],
      "validation": "warn"
    },
    "amount": {
      "header": "Сумма",
      "type": "number",
      "numberFormat": "#,##0.00",
      "horizontalAlignment": "RIGHT"
    },
    "rate": {
      "header": "Курс",
      "type": "formula",
      "formula": "=SWITCH({currency}{row}; \"USD\"; 1; \"SOM\"; IFERROR(INDEX(GOOGLEFINANCE(\"CURRENCY:USDUZS\"; \"price\"; {date}{row}); 2; 2); INDEX(GOOGLEFINANCE(\"CURRENCY:USDUZS\"; \"price\"; WORKDAY({date}{row}; -1)); 2; 2)); \"RUB\"; IFERROR(INDEX(GOOGLEFINANCE(\"CURRENCY:USDRUB\"; \"price\"; {date}{row}); 2; 2); INDEX(GOOGLEFINANCE(\"CURRENCY:USDRUB\"; \"price\"; WORKDAY({date}{row}; -1)); 2; 2)); \"EUR\"; IFERROR(INDEX(GOOGLEFINANCE(\"CURRENCY:USDEUR\"; \"price\"; {date}{row}); 2; 2); INDEX(GOOGLEFINANCE(\"CURRENCY:USDEUR\"; \"price\"; WORKDAY({date}{row}; -1)); 2; 2)); NA())",
      "numberFormat": "#,##0.00"
    },
    "currency": {
      "header": "Валюта",
      "type": "enum",
      "values": ["USD", "SOM", "EUR", "RUB"],
      "validation": "strict"
    },
    "usdAmount": {
      "header": "Сумма ($)",
      "type": "formula",
      "formula": "={amount}{row}/{rate}{row}",
      "numberFormat": "[$$-409]#,##0.00",
      "horizontalAlignment": "RIGHT"
    },
    "period": {
      "header": "Расчетный период",
      "type": "computed",
      "compute": "firstOfMonth(date)",
      "numberFormat": "DD.MM.YYYY"
    },
    "account": {
      "header": "Счет",
      "type": "ref",
      "refSheet": "счета",
      "refColumn": "name"
    },
    "employee": {
      "header": "Сотрудник",
      "type": "string",
      "optional": true
    },
    "description": {
      "header": "Описание",
      "type": "string",
      "optional": true
    }
  },
  "sheetProperties": {
    "frozenRows": 1,
    "headerStyle": {
      "textFormat": { "bold": true },
      "backgroundColor": "#e8eaed",
      "horizontalAlignment": "CENTER"
    }
  },
  "conditionalFormats": []
}
