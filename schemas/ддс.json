{
  "$schema": "../mcp/schema-spec.md",
  "sheet": "ддс",
  "headerRow": 3,
  "primaryKey": ["date", "amount", "outAccount", "inAccount"],
  "columns": {
    "date": {
      "header": "Дата",
      "type": "date",
      "numberFormat": "DD.MM.YYYY",
      "horizontalAlignment": "RIGHT"
    },
    "amount": {
      "header": "Сумма",
      "type": "number",
      "numberFormat": "#,##0.00",
      "horizontalAlignment": "RIGHT"
    },
    "outAccount": {
      "header": "Исходящий счет",
      "type": "ref",
      "refSheet": "счета",
      "refColumn": "name"
    },
    "inAccount": {
      "header": "Входящий счет",
      "type": "ref",
      "refSheet": "счета",
      "refColumn": "name"
    },
    "type": {
      "header": "Тип",
      "type": "enum",
      "values": ["P2P", "Банковский перевод", "Конвертация", "Снятие", "Зачисление"],
      "validation": "warn"
    },
    "period": {
      "header": "Рассчетный период",
      "type": "computed",
      "compute": "firstOfMonth(date)",
      "numberFormat": "DD.MM.YYYY"
    },
    "exchangeRate": {
      "header": "Обменный курс",
      "type": "number",
      "numberFormat": "#,##0.0000",
      "optional": true
    },
    "comment": {
      "header": "Комментарий",
      "type": "string",
      "optional": true
    }
  },
  "sheetProperties": {
    "frozenRows": 3,
    "headerStyle": {
      "textFormat": { "bold": true },
      "backgroundColor": "#e8eaed",
      "horizontalAlignment": "CENTER"
    }
  }
}
