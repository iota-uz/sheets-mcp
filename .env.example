# Absolute path to your Google service-account JSON key.
# Required. The MCP throws on startup if this isn't reachable.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional — only if you use the discord_read_messages tool.
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
# DISCORD_IMAGES_DIR=./reports/discord
